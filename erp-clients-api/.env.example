# Oracle (same as Laravel .env)
ORACLE_DSN=10.1.4.101:18032/PDBTQUEST
ORACLE_USER=TQ_LMS
ORACLE_PASSWORD=TQ#LMS2019c

# Optional - match Laravel config
ERP_CLIENTS_VIEW=LMS_INDIVIDUAL_CRM_VIEW
ERP_CLIENTS_LIST_COLUMNS=POLICY_NUMBER,PRODUCT,POL_PREPARED_BY,INTERMEDIARY,STATUS,KRA_PIN,PRP_DOB,EFFECTIVE_DATE,MATURITY
ERP_CLIENTS_LIST_SEARCH_COLUMNS=POLICY_NUMBER,POL_PREPARED_BY,INTERMEDIARY,KRA_PIN
ERP_CLIENTS_LIST_ORDER=PRODUCT
# Group view (LMS_GROUP_CRM_VIEW) - may have different columns (e.g. SCHEME_NAME, MEMBER_NAME)
ERP_CLIENTS_GROUP_VIEW=TQ_LMS.LMS_GROUP_CRM_VIEW
# Optional: Support > Clients pills system=mortgage | system=group_pension (empty list until set)
# ERP_CLIENTS_MORTGAGE_VIEW=TQ_LMS.LMS_MORTGAGE_CRM_VIEW
# ERP_CLIENTS_GROUP_PENSION_VIEW=TQ_LMS.LMS_GROUP_PENSION_CRM_VIEW
ERP_CLIENTS_GROUP_COLUMNS=POLICY_NUMBER,PRODUCT,POL_PREPARED_BY,INTERMEDIARY,STATUS,KRA_PIN
ERP_CLIENTS_GROUP_SEARCH_COLUMNS=POLICY_NUMBER,POL_PREPARED_BY,INTERMEDIARY,KRA_PIN

# Group Life: GROUP BY column (one row per policy). Use POL_POLICY_NO if your view has no IPOL_POLICY_NO.
# ERP_GROUP_GROUP_BY_COLUMN=POL_POLICY_NO
ERP_GROUP_POLICY_COLUMN=POL_POLICY_NO
ERP_GROUP_PRODUCT_COLUMN=PROD_DESC
# Never use Individual view for Group Life list – keep false to use actual LMS_GROUP_CRM_VIEW (2,422 rows).
# When true, would mix Individual policies (IL-AEP-*, etc.) into Group Life and show wrong count.
# ERP_GROUP_FROM_INDIVIDUAL_ONLY=false
# When Group returns 0 for policy search only, try Individual (policy may be in either view).
# List view never falls back – only policy/search lookup.
# ERP_GROUP_FALLBACK_TO_INDIVIDUAL=false

# Server
PORT=5000
FLASK_DEBUG=false
