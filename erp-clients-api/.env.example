# Oracle (same as Laravel .env)
ORACLE_DSN=10.1.4.101:18032/PDBTQUEST
ORACLE_USER=TQ_LMS
ORACLE_PASSWORD=TQ#LMS2019c

# Optional - match Laravel config
ERP_CLIENTS_VIEW=LMS_INDIVIDUAL_CRM_VIEW
ERP_CLIENTS_LIST_COLUMNS=POLICY_NUMBER,PRODUCT,POL_PREPARED_BY,INTERMEDIARY,STATUS,KRA_PIN,PRP_DOB,EFFECTIVE_DATE,MATURITY
ERP_CLIENTS_LIST_SEARCH_COLUMNS=POLICY_NUMBER,POL_PREPARED_BY,INTERMEDIARY,KRA_PIN
ERP_CLIENTS_LIST_ORDER=PRODUCT
# Group view (LMS_GROUP_CRM_VIEW) - may have different columns (e.g. SCHEME_NAME, MEMBER_NAME)
ERP_CLIENTS_GROUP_VIEW=TQ_LMS.LMS_GROUP_CRM_VIEW
ERP_CLIENTS_GROUP_COLUMNS=POLICY_NUMBER,PRODUCT,POL_PREPARED_BY,INTERMEDIARY,STATUS,KRA_PIN
ERP_CLIENTS_GROUP_SEARCH_COLUMNS=POLICY_NUMBER,POL_PREPARED_BY,INTERMEDIARY,KRA_PIN

# Group Life: GROUP BY IPOL_POLICY_NO (one row per policy); product from PROD_DESC
ERP_GROUP_GROUP_BY_COLUMN=IPOL_POLICY_NO
ERP_GROUP_POLICY_COLUMN=POL_POLICY_NO
ERP_GROUP_PRODUCT_COLUMN=PROD_DESC
# When Group returns 0 for policy search, try Individual view (policy may be misclassified)
ERP_GROUP_POLICY_SEARCH_FALLBACK=true

# Server
PORT=5000
FLASK_DEBUG=false
