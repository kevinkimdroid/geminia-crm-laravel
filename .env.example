APP_NAME=Laravel
# PRODUCTION: Set APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-domain.com
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Nairobi
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Use 'file' for faster performance (single server). Use 'database' or 'redis' for multi-server.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Production: use 'database' (no storage/framework/cache permissions needed).
# Local/dev: 'file' is fine. Use 'redis' for best performance under load.
CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"

# Microsoft Graph (Office 365) mail integration
MSGRAPH_ENABLED=false
MSGRAPH_TENANT_ID=common
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_MAILBOX=
MSGRAPH_FETCH_LIMIT=25
# Pension Administration inbox (Support → Pension Administration)
# PENSIONS_MAILBOX=pensions@geminialife.co.ke
# PENSIONS_GRAPH_FETCH_MAILBOX=pensions.support@geminialife.co.ke
# Group mailbox (no password): IT provides Azure group Object ID OR grants Group.Read.All on the CRM app
# MSGRAPH_PENSIONS_GROUP_ID=
# Auto-create tickets from client emails on the pension mailbox
# PENSION_AUTO_TICKET_ENABLED=true
# PENSION_AUTO_TICKET_ASSIGN_TO=daniel.wangendo@geminialife.co.ke
# PENSION_AUTO_TICKET_ESCALATE_TO=caroline.wanjiku@geminialife.co.ke
# PENSION_AUTO_TICKET_TAT_HOURS=24
# PENSION_AUTO_TICKET_CATEGORY="Pension Administration"
# PENSION_FETCH_LIMIT=1000
# PENSION_INBOX_EXCLUDE_ADDRESSES=pensions.support@geminialife.co.ke
# PENSION_TICKET_ORGANIZATION="line:Group Pension"
MSGRAPH_CONNECT_TIMEOUT=10
MSGRAPH_TIMEOUT=20
MSGRAPH_RETRIES=2
MSGRAPH_RETRY_SLEEP_MS=300
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ERP (Oracle/PL-SQL) - requires yajra/laravel-oci8 and OCI8 extension
# composer require yajra/laravel-oci8:^12
# ERP_ENABLED=true  (set false to disable Oracle when credentials unreachable)
# ERP_CREDENTIALS_FILE=  (optional - path to JSON file for credentials; use for passwords with # or special chars)
# ERP_API_TOKEN=  (required - secure token for /api/erp/clients)
# ERP_HOST=
# ERP_PORT=1521
# ERP_SERVICE_NAME=
# ERP_DATABASE=
# ERP_USERNAME=
# ERP_PASSWORD=  (use quotes if value contains # : ERP_PASSWORD="TQ#2019c")
# ERP_TNS=  (optional - use instead of host/port/service_name)
# ERP_CLIENTS_TABLE=CLIENTS
# ERP_CLIENTS_SOURCE=table  (table|procedure|http)
# Clients list (Support > Customers) - use LMS_INDIVIDUAL_CRM_VIEW for fast paginated list:
# CLIENTS_VIEW_SOURCE=erp  (erp=oracle view, crm=vtiger contacts)
# ERP_CLIENTS_LIST_TABLE=TQ_LMS.LMS_INDIVIDUAL_CRM_VIEW
# Group view for system=group filter: ERP_CLIENTS_GROUP_VIEW=TQ_LMS.LMS_GROUP_CRM_VIEW
# Individual view for system=individual: ERP_CLIENTS_INDIVIDUAL_VIEW=TQ_LMS.LMS_INDIVIDUAL_CRM_VIEW
# Mortgage / Group Pension (system=mortgage | system=group_pension); optional ERP_MORTGAGE_KEYWORDS / ERP_GROUP_PENSION_KEYWORDS for erp_sync cache filters
# ERP_CLIENTS_MORTGAGE_VIEW=TQ_LMS.LMS_GROUP_MORTAGE_VIEW
# Match erp-clients-api: pipe = COALESCE, e.g. MENDR_RENEWAL_DATE|MATURITY_DATE for group mortgage views.
# ERP_CLIENTS_MORTGAGE_RENEWAL_DATE_COLUMN=MENDR_RENEWAL_DATE|MATURITY_DATE
# ERP_CLIENTS_GROUP_PENSION_VIEW=TQ_LMS.LMS_GROUP_PENSION
# Optional Support > Clients filter pill labels (URLs still use system=group, etc.)
# CLIENTS_TAB_LABEL_GROUP="Group Life"
# CLIENTS_TAB_LABEL_GROUP_PENSION="Group Pension"
# ERP_CLIENTS_LIST_COLUMNS=POLICY_NO,POLICY_NUMBER,CLIENT_NAME,FIRST_NAME,LAST_NAME,EMAIL,PHONE,MOBILE,PRODUCT
# ERP_CLIENTS_LIST_ORDER=PRODUCT
# ERP_CLIENTS_VIEW=  (optional - view wrapping procedure)
# ERP_CLIENTS_HTTP_URL=  (when source=http)
# Group Life vs Individual Life - product keywords (comma-separated, case-insensitive):
# ERP_GROUP_LIFE_KEYWORDS=GROUP,GL,CREDIT LIFE
# ERP_INDIVIDUAL_LIFE_KEYWORDS=INDIVIDUAL,IL,LIFE
# Agency advances (AGNADV): daily email when ERP returns rows (see finance:notify-agency-advances)
# FINANCE_AGENCY_ADVANCES_NOTIFY_ENABLED=false
# FINANCE_AGENCY_ADVANCES_NOTIFY_RECIPIENT=kelvin.kimutai@geminialife.co.ke
# ERP SMS life messages (see erp:send-sms-messages and Tools > ERP Messaging)
# --- PRODUCTION SERVER (minimum) ---
# 1) erp-clients-api running on app server or LAN host (not 127.0.0.1 unless API is on same machine)
# 2) FINANCE_ERP_HTTP_BASE=http://YOUR_ERP_API_HOST:5000  (then: php artisan config:clear)
# 3) ADVANTA_API_KEY, ADVANTA_PARTNER_ID, ADVANTA_SHORTCODE on server .env
# 4) ERP_MESSAGES_AUTO_SEND_ENABLED=true
# 5) Cron: * * * * * cd /path/to/crm && php artisan schedule:run
# 6) QUEUE_CONNECTION=database + supervisor/systemd: php artisan queue:work (for UI "Send now")
# Verify: php artisan erp:diagnose-sms  &&  php artisan erp:send-sms-messages --limit=5
# --- LOCAL DEV ---
# FINANCE_ERP_HTTP_BASE=http://127.0.0.1:5000  +  scripts\start-erp-sms-dev.bat  OR  composer run dev
# When FINANCE_ERP_HTTP_BASE is set, CRM uses erp-clients-api /messages/sms/* by default (avoids ORA-03113 from PHP OCI8).
# ERP_MESSAGES_HTTP=auto
# (auto|http|oracle)
# Optional: API root for SMS routes only (when different from finance). Else uses FINANCE_ERP_HTTP_BASE or derived root from ERP_CLIENTS_HTTP_URL.
# ERP_MESSAGES_HTTP_BASE=http://10.1.4.101:5000
# ERP_MESSAGES_HTTP_TOKEN=
# ERP_MESSAGES_TABLE=tq_crm.tqc_smslife_messages
# ERP_MESSAGES_STATUS_COLUMN=sms_status
# ERP_MESSAGES_PENDING_STATUS=D
# ERP_MESSAGES_SENT_STATUS=OK
# ERP_MESSAGES_FAILED_STATUS=E
# ERP_MESSAGES_SENT_DATE_COLUMN=
# ERP_MESSAGES_AUTO_SEND_ENABLED=false
# ERP_SMS_ALLOW_HISTORY_RESEND=false
# ERP_MESSAGES_AUTO_SEND_LIMIT=50
# ERP_MESSAGES_FAILURE_NOTIFY_ENABLED=true
# ERP_MESSAGES_FAILURE_NOTIFY_RECIPIENT=kelvin.kimutai@geminialife.co.ke
# ERP_MESSAGES_FAILURE_NOTIFY_CC=evans.wanguba@geminialife.co.ke
# ERP_MESSAGES_HTTP_TIMEOUT=45
# ERP_MESSAGES_SEND_VIA_QUEUE=true
# ADVANTA_HTTP_TIMEOUT=15
# ADVANTA_SEND_MAX_ATTEMPTS=3
# ADVANTA_SEND_RETRY_DELAY_MS=500
# ADVANTA_TEST_MOBILE=2547XXXXXXXX  (for php artisan erp:diagnose-sms --test-advanta)
# Use QUEUE_CONNECTION=database (not sync) so Send now returns immediately; run php artisan queue:work
# After updating erp-clients-api/app.py, restart the Python API (composer run dev restarts it)
# Finance cheques without PHP OCI8: same host as erp-clients-api (base URL only, no /clients path)
# FINANCE_ERP_HTTP_BASE=http://127.0.0.1:5000
# If unset, API root is derived from ERP_CLIENTS_HTTP_URL: any path before …/api/clients or …/clients is kept
# (e.g. https://gw.example.com/erp-clients/api/clients → https://gw.example.com/erp-clients). Then php artisan config:clear.
# Optional Bearer token — set ERP_FINANCE_API_TOKEN (or ERP_API_TOKEN) on erp-clients-api to match
# FINANCE_ERP_HTTP_TOKEN=

# Social Media OAuth & Webhooks
# FACEBOOK_CLIENT_ID= / FACEBOOK_CLIENT_SECRET=
# INSTAGRAM_CLIENT_ID= / INSTAGRAM_CLIENT_SECRET=  (or same as Facebook)
# TWITTER_CLIENT_ID= / TWITTER_CLIENT_SECRET=
# TWITTER_REDIRECT_URI=  (optional - defaults to APP_URL/social-auth/twitter/callback)
# GOOGLE_CLIENT_ID= / GOOGLE_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY= / TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=  (optional - defaults to APP_URL/social-auth/tiktok/callback)
# Webhook URLs (defaults use APP_URL if unset). Meta: same path for Page + Instagram.
# SOCIAL_WEBHOOK_FACEBOOK=${APP_URL}/webhooks/social/meta
# SOCIAL_WEBHOOK_INSTAGRAM=${APP_URL}/webhooks/social/meta
# SOCIAL_WEBHOOK_TIKTOK=${APP_URL}/webhooks/social/ingest
# SOCIAL_WEBHOOK_TWITTER=${APP_URL}/webhooks/social/ingest
# SOCIAL_WEBHOOK_GOOGLE=${APP_URL}/webhooks/social/ingest
# META_WEBHOOK_VERIFY_TOKEN=long-random-string   (Meta "Verify token" in app webhook settings)
# META_APP_SECRET=   (optional; defaults to FACEBOOK_CLIENT_SECRET for signature check)
# SOCIAL_WEBHOOK_SKIP_SIGNATURE_VERIFY=false   (true only for local tunnel testing)
# SOCIAL_WEBHOOK_ENRICH_GRAPH=false   (fetch comment details via Graph API when token available)
# SOCIAL_WEBHOOK_INGEST_TOKEN=   (Bearer token for POST /webhooks/social/ingest)

# PBX Manager - Uses vtiger_pbxmanager_gateway from old CRM when available.
# Otherwise, set API URL to fetch call logs (JSON with calls array):
# PBX_API_URL=
# PBX_API_KEY=
# Duration columns (if always 0, run: php artisan pbx:inspect-schema --sample)
# PBX_DURATION_COLUMNS=billduration,totalduration
# Make Call: webapp URL (Vtiger Asterisk App / PBX webapp) - used when vtiger gateway is not available:
# PBX_WEBAPP_URL=http://10.1.1.86:8383
# Full URL for Make Call API if PBX uses a different endpoint:
# PBX_MAKE_CALL_URL=http://10.1.1.86:8383/makeCall
# Incoming call webhook endpoint (configure on PBX connector/webapp):
# ${APP_URL}/webhooks/pbx/incoming
# PBX should send: event=IncomingCall, sourceuuid/callid, from(customernumber), to(extension), status.
# Default SIP extension for Make Call (optional - user can enter each time):
# PBX_DEFAULT_EXTENSION=101
# Set to true to log makeCall requests/responses to storage/logs/laravel.log (for debugging):
# PBX_DEBUG=false
# Kenya numbers: add 254 prefix when number is 9 digits starting with 7 (default: true):
# PBX_NUMBER_ADD_PREFIX=true
# PBX_NUMBER_COUNTRY_CODE=254
# Optional direct CDR DB connection (use when vtiger DB user cannot read asteriskcdrdb.cdr):
# PBX_CDR_DB_HOST=10.1.1.86
# PBX_CDR_DB_PORT=3306
# PBX_CDR_DB_DATABASE=asteriskcdrdb
# PBX_CDR_DB_USERNAME=
# PBX_CDR_DB_PASSWORD=

# Advanta SMS (Kenya) - https://www.advantasms.com
# ADVANTA_API_KEY=
# ADVANTA_PARTNER_ID=
# ADVANTA_SHORTCODE=

# Auto-create tickets: Maturity reminders (multi-horizon: 61–90d, 31–60d, 1–30d by default)
# TICKET_AUTO_MATURITY_ENABLED=false
# TICKET_AUTO_MATURITY_DAYS_BEFORE=30
# TICKET_AUTO_MATURITY_ASSIGN_TO=1
# TICKET_AUTO_MATURITY_CATEGORY=Policy Document
# TICKET_AUTO_MATURITY_USE_HORIZONS=true
# TICKET_AUTO_MATURITY_HORIZONS=90,60,30
# TICKET_AUTO_MATURITY_PRODUCT_ASSIGNEES={"INDIVIDUAL LIFE":1,"GROUP LIFE":2}

# Discharge voucher PDF (Support → Maturing policies): optional wording overrides
# DISCHARGE_VOUCHER_TITLE=Discharge Voucher
# DISCHARGE_VOUCHER_SUBTITLE=Policy maturity — discharge of obligations under the policy contract
# DISCHARGE_VOUCHER_ISSUER=Geminia Life — Client Service
# DISCHARGE_VOUCHER_SIGNATORY_LABEL=Authorised signatory
# DISCHARGE_VOUCHER_EXTRA=

# Auto-create ticket from inbound email + send auto-reply with ticket number
# TICKET_AUTO_FROM_EMAIL_ENABLED=false
# TICKET_AUTO_FROM_EMAIL_ASSIGN_TO=1
# TICKET_AUTO_FROM_EMAIL_CATEGORY=Other
# TICKET_AUTO_FROM_EMAIL_SOURCE=Email
# TICKET_AUTO_REPLY_ENABLED=true
# TICKET_AUTO_REPLY_SUBJECT=Re: {{subject}} - Ticket {{ticket_number}}
# TICKET_AUTO_REPLY_BODY=Thank you for your email. We have created a support ticket ({{ticket_number}}) for your inquiry. Our team will respond shortly.

# Auto-create complaint in Complaint Register from inbound email (IRA compliance, runs with auto-ticket)
# COMPLAINTS_AUTO_FROM_EMAIL_ENABLED=true
# COMPLAINTS_AUTO_FROM_EMAIL_NATURE=Other
# COMPLAINTS_AUTO_FROM_EMAIL_PRIORITY=Medium

# Notify on ticket creation: email assigned user and/or contact when ticket is created
# TICKET_NOTIFY_ON_CREATION_ENABLED=true
# TICKET_NOTIFY_ASSIGNED_USER=true
# Client emails OFF by default. Set TICKET_NOTIFY_CONTACT=true to email clients when ticket is created.
TICKET_NOTIFY_CONTACT=false

# SLA violation reminders: email assigned user when ticket exceeds TAT (runs hourly)
# TICKET_SLA_REMINDERS_ENABLED=true
# TICKET_SLA_REMINDERS_CC=caroline.wanjiku@geminialife.co.ke

# Feedback: public base URL for closed-ticket email links (no trailing slash). Browser opens FEEDBACK_PUBLIC_URL + / + FEEDBACK_PUBLIC_PATH
# Example with Laravel public/: https://services.geminialife.co.ke:9443/crm-client-feedback/…
# FEEDBACK_PUBLIC_URL=https://services.geminialife.co.ke:9443
# FEEDBACK_PUBLIC_PATH=crm-client-feedback
# CRM base URL for crm-client-feedback to call /api/feedback/* (same host as this app when bundled).
# FEEDBACK_CRM_API_URL=https://services.geminialife.co.ke:9443
# Feedback API: when true, /api/feedback/validate and /api/feedback/submit always return an error (for testing)
# FEEDBACK_API_FORCE_ERROR=true

# Auto-fetch emails via scheduler (runs every 5 min when Laravel cron runs)
# MAIL_AUTO_FETCH_ENABLED=true
# Set MAIL_MAILER=smtp (not log) for actual delivery of auto-reply emails, or use Microsoft Graph (auto-reply sends via Graph when configured)

# Exclude organization domains from tickets/complaints - only client emails processed (comma-separated)
# EMAIL_EXCLUDED_SENDER_DOMAINS=geminialife.co.ke,gab.co.ke,centralbank.go.ke

# Dashboard: show organization-wide stats for all users (Pipeline, Leads, Deals). Set false for per-user stats.
DASHBOARD_SHOW_ALL_STATS=true

# Dashboard floating staff notice (home page only). Change DASHBOARD_STAFF_BANNER_ID when publishing a new notice.
# DASHBOARD_STAFF_BANNER_ENABLED=true
# DASHBOARD_STAFF_BANNER_ID=2026-05-13
# DASHBOARD_STAFF_BANNER_TITLE=Notice for staff
# DASHBOARD_STAFF_BANNER_MESSAGE=Example: ERP client lookup is in maintenance tonight from 8 PM to 10 PM.
# DASHBOARD_STAFF_BANNER_VARIANT=info
# DASHBOARD_STAFF_BANNER_LINK_URL=
# DASHBOARD_STAFF_BANNER_LINK_LABEL=Learn more

# Mass email/SMS broadcast: skip contacts who already received the same channel within N days (when enabled on the form)
# BROADCAST_SKIP_RECENT_DAYS=14
